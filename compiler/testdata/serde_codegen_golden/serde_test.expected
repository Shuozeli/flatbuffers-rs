pub fn size_prefixed_root_as_monster(buf: &[u8]) -> Result<serde_test::Monster<'_>, ::flatbuffers::InvalidFlatbuffer> {
  ::flatbuffers::size_prefixed_root::<serde_test::Monster>(buf)
}

#[inline]
/// # Safety
/// Caller must ensure the buffer contains a valid FlatBuffer.
pub unsafe fn root_as_monster_unchecked(buf: &[u8]) -> serde_test::Monster<'_> {
  unsafe { ::flatbuffers::root_unchecked::<serde_test::Monster>(buf) }
}
